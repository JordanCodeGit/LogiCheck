# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/logicheck

# Google Gemini API - Server-managed keys (not exposed to frontend)
# You can add multiple keys for load balancing/fallback
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_second_api_key_here
GEMINI_API_KEY_3=your_third_api_key_here
GEMINI_API_KEY_4=your_fourth_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
