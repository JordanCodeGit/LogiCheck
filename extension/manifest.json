{
  "manifest_version": 3,
  "name": "LogiCheck Lens",
  "description": "Your AI coach for sharpening logical reasoning. Analyze text on any webpage.",
  "version": "1.0.5",
  "icons": {
    "16": "images/logo_logicheck_extension.png",
    "32": "images/logo_logicheck_extension.png",
    "48": "images/logo_logicheck_extension.png",
    "128": "images/logo_logicheck_extension.png"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/logo_logicheck_extension.png",
      "32": "images/logo_logicheck_extension.png",
      "48": "images/logo_logicheck_extension.png",
      "128": "images/logo_logicheck_extension.png"
    },
    "default_title": "LogiCheck Lens - Quick Access"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-modern.js"]
    }
  ],
  "commands": {
    "analyze-text": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Analyze selected text with LogiCheck"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["images/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
